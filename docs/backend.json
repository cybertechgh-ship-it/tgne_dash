
{
  "entities": {
    "Client": {
      "title": "Client",
      "description": "Store client/business information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "businessName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "notes": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "businessName"]
    },
    "Website": {
      "title": "Website",
      "description": "Each client can have multiple websites",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "domainName": { "type": "string" },
        "url": { "type": "string" },
        "platform": { "type": "string", "enum": ["WordPress", "Shopify", "Custom", "Other"] },
        "hostingProvider": { "type": "string" },
        "dateCreated": { "type": "string", "format": "date-time" },
        "projectPrice": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["Paid", "Unpaid"] },
        "expiryDate": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "domainName"]
    },
    "Credential": {
      "title": "Credential",
      "description": "Securely store login credentials per website",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "type": { "type": "string", "enum": ["cPanel", "Hosting", "Domain Registrar", "WordPress Admin", "Other"] },
        "username": { "type": "string" },
        "password": { "type": "string", "description": "Simulated encrypted password" },
        "url": { "type": "string" }
      },
      "required": ["clientId", "type", "username", "password"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Track payments and receipts",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["PAID", "PENDING"] },
        "paymentDate": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "amount", "status", "invoiceNumber"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "Track domain/hosting/management alerts",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["Web Management", "Domain", "Hosting", "Payment"] },
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "details": { "type": "string" }
      },
      "required": ["type", "title", "date"]
    },
    "Task": {
      "title": "Task",
      "description": "Track developer tasks per client",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "In Progress", "Completed"] },
        "dueDate": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "description", "status"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "clients": { "schema": "#/entities/Client", "description": "Business clients" },
    "websites": { "schema": "#/entities/Website", "description": "Digital properties" },
    "credentials": { "schema": "#/entities/Credential", "description": "Login details" },
    "payments": { "schema": "#/entities/Payment", "description": "Invoices and payments" },
    "reminders": { "schema": "#/entities/Reminder", "description": "Expirations and alerts" },
    "tasks": { "schema": "#/entities/Task", "description": "Management tasks" }
  }
}
